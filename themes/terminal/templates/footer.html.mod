<div class="terminal-body terminal-footer-body">
  <div class="terminal-footer-content">
    <span class="terminal-prompt">❯</span>
    <span class="terminal-status">system normal</span>
    <span class="terminal-separator">|</span>
    <span class="terminal-timestamp">{{currentYear}}</span>
    <span class="terminal-separator">|</span>
    <span class="terminal-brand">FearlessCMS</span>
  </div>
  <div class="terminal-footer-line">
    <span class="terminal-prompt">❯</span>
    <span class="terminal-cursor"></span>
  </div>
</div>
